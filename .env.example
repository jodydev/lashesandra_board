# Copia in .env e compila con i valori reali.
# Usato sia per web (npm run build) che per mobile (npm run build:mobile).

# Supabase (obbligatorio)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# WhatsApp / Twilio (opzionale, per invio messaggi)
# VITE_WHATSAPP_MODE=production
# VITE_TWILIO_ACCOUNT_SID=
# VITE_TWILIO_AUTH_TOKEN=
# VITE_TWILIO_PHONE_NUMBER=
